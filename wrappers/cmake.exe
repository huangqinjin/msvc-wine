. $(dirname $0)/msvcenv.sh

CMAKEDIR=$BASE_UNIX/Common7/IDE/CommonExtensions/Microsoft/CMake
export PATH=$PATH:$CMAKEDIR/Ninja

if [ -z "$CMAKE_GENERATOR" ]; then
    export CMAKE_GENERATOR="Visual Studio 17 2022"
    export CMAKE_GENERATOR_INSTANCE=$BASE,version=17.0.0.0
    export CMAKE_GENERATOR_PLATFORM=$ARCH,version=$SDKVER
    export CMAKE_WINDOWS_KITS_10_DIR=$SDKBASE
fi

export WINE_MSVC_RAW_STDOUT=1
$(dirname $0)/wine-msvc.sh $CMAKEDIR/CMake/bin/cmake.exe "$@"
